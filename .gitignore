# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Gradle build output
build/

# Gradle cache
.gradle/

# IntelliJ IDEA IDE files
.idea/

# Keep the Gradle wrapper jar (overrides *.jar rule above)
!gradle/wrapper/gradle-wrapper.jar
